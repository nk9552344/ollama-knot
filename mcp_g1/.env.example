# Copy to .env for local development:
# cp .env.example .env

# Path to the policy registry YAML file.
POLICY_REGISTRY_PATH=./policies.yaml

# Redis connection URL.
REDIS_URL=redis://localhost:6379/0

# Redis queue used by the MCP to enqueue policy execution requests.
# The MCP only writes to this queue.
COMMAND_QUEUE_NAME=policy:commands

# Redis queue used by the robot to publish execution events.
# The MCP only reads from this queue.
EVENT_QUEUE_NAME=policy:events

# MCP transport:
#   stdio - Local subprocess (e.g. Claude Desktop)
#   http  - Streamable HTTP (recommended for Docker)
#   sse   - Server-Sent Events
MCP_TRANSPORT=http

# Bind address when MCP_TRANSPORT=http or sse.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Streamable HTTP configuration.
MCP_STATELESS_HTTP=true
MCP_JSON_RESPONSE=true