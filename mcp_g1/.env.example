# Copy to .env for local development: `cp .env.example .env`

# Path to the YAML policy registry. In Docker this is the in-container path
# where the registry file is mounted (see docker-compose.yml).
POLICY_REGISTRY_PATH=./policies.yaml

# Redis connection URL.
REDIS_URL=redis://localhost:6379/0

# Redis list used as the policy execution queue.
REDIS_QUEUE_NAME=policy_queue

# "stdio" for local subprocess use (e.g. Claude Desktop),
# "http"  for streamable-HTTP transport (recommended in Docker).
MCP_TRANSPORT=stdio

# Bind address when MCP_TRANSPORT=http.
MCP_HOST=0.0.0.0
MCP_PORT=8000
